# Murder Mystery — environment variables
# Copy this file to .env and fill in your values.
# .env is never committed to git.
#
# How resolution works:
# - LLM_PROVIDER picks the branch ("openai" | "backend" | "anthropic")
# - LLM_BASE_URL is an OPTIONAL override; leave empty to use the provider's
#   own default (Ollama for openai, BACKEND_URL for backend, Anthropic API
#   for anthropic).
# - DEFAULT_MODEL is the fallback for the three roles.
#   You can override per-role: WRITER_MODEL / DETECTIVE_MODEL / SUSPECT_MODEL.

# ── Default: Ollama (local, free) ─────────────────────────────────────────────
# Install Ollama from https://ollama.com, then: ollama pull llama3.2
LLM_PROVIDER=openai
DEFAULT_MODEL=llama3.2
# LLM_BASE_URL is empty → falls back to http://localhost:11434/v1

# ── Local custom backend ──────────────────────────────────────────────────────
# Custom proxy with /llm endpoint. Requires BACKEND_URL and BACKEND_KEY.
# LLM_PROVIDER=backend
# BACKEND_URL=http://127.0.0.1:19000
# BACKEND_KEY=your-key
# DEFAULT_MODEL=gemma4-e4b

# ── OpenAI ────────────────────────────────────────────────────────────────────
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# DEFAULT_MODEL=gpt-4o-mini

# ── Anthropic ─────────────────────────────────────────────────────────────────
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-...
# DEFAULT_MODEL=claude-haiku-4-5

# ── Groq, Mistral, DeepSeek, OpenRouter... ────────────────────────────────────
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_...
# DEFAULT_MODEL=llama-3.3-70b-versatile

# ── Per-role overrides (optional) ─────────────────────────────────────────────
# WRITER_MODEL=gpt-4o
# DETECTIVE_MODEL=gpt-4o-mini
# SUSPECT_MODEL=gpt-4o-mini

# ── Web server (optional) ─────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=7860
